<%
const maxBatch = 7;
const hasStruct = typeof contractName === "string" && contractName.trim() !== "";
const verifierName = hasStruct ? contractName.trim() : null;
const publicContractName = verifierName ?? "Verifier";
const storageName = `${publicContractName}Storage`;
const verifyMessageName = hasStruct ? `${verifierName}Verify` : "Verify";
const verifyGetterName = hasStruct ? `verify_${verifierName}` : null;
const errorsName = `${publicContractName}Errors`;
const errInvalidInputs = `${errorsName}.InvalidInputs`;
const errIndexOutOfRange = `${errorsName}.IndexOutOfRange`;
const errWrongProof = `${errorsName}.WrongProof`;

let sizes = [];

if (nPublic > 0) {
  if (nPublic <= maxBatch) {
    sizes = [nPublic];
  } else {
    const fullBatches = Math.floor(nPublic / maxBatch);
    for (let i = 0; i < fullBatches; i++) sizes.push(maxBatch);
    const rem = nPublic % maxBatch;
    if (rem > 0) sizes.push(rem);
  }
}

const uniqSizes = [...new Set(sizes)];
const tailSizes = uniqSizes.filter((s) => s !== 7).sort((a, b) => a - b);
function icFieldName(i) {
  return `ic${i}`;
}

const icFieldDecls = IC.map((_, i) => `  ${icFieldName(i)}: slice`).join("\n");
const icFieldValues = IC
  .map((point, i) => `    ${icFieldName(i)}: "${point}".hexToSlice(),`)
  .join("\n");
const verifierFieldDecls = [
  icFieldDecls,
  "  vkGamma2: slice",
  "  vkDelta2: slice",
  "  vkAlpha1: slice",
  "  vkBeta2: slice",
  "  nPublic: int",
].join("\n");
const verifierFieldValues = [
  icFieldValues,
  `    vkGamma2: "${vk_gamma_2}".hexToSlice(),`,
  `    vkDelta2: "${vk_delta_2}".hexToSlice(),`,
  `    vkAlpha1: "${vk_alpha_1}".hexToSlice(),`,
  `    vkBeta2: "${vk_beta_2}".hexToSlice(),`,
  `    nPublic: ${nPublic},`,
].join("\n");
const icConstants = !hasStruct
  ? IC.slice(0, nPublic > maxBatch ? 1 : undefined)
      .map((point, i) => `const IC${i}: slice = "${point}".hexToSlice()`)
      .join("\n")
  : "";
const icSelectorCases = IC
  .slice(1)
  .map((point, i) =>
    hasStruct
      ? `  if (idx == ${i + 1}) { return self.${icFieldName(i + 1)}; }`
      : `  if (idx == ${i + 1}) { return "${point}".hexToSlice(); }`,
  )
  .join("\n");
const nPublicExpr = hasStruct ? "self.nPublic" : "N_PUBLIC";
const icZeroExpr = hasStruct ? "self.ic0" : "IC0";
const vkGammaExpr = hasStruct ? "self.vkGamma2" : "VK_GAMMA_2";
const vkDeltaExpr = hasStruct ? "self.vkDelta2" : "VK_DELTA_2";
const vkAlphaExpr = hasStruct ? "self.vkAlpha1" : "VK_ALPHA_1";
const vkBetaExpr = hasStruct ? "self.vkBeta2" : "VK_BETA_2";
const addCall = hasStruct ? `${verifierName}.blsG1Add` : "blsG1Add";
const negCall = hasStruct ? `${verifierName}.blsG1Neg` : "blsG1Neg";
const pairingCall = hasStruct ? `${verifierName}.blsPairing` : "blsPairing";
const loadNextPubInputCall = hasStruct
  ? `${verifierName}.loadNextPubInput(mutate payload)`
  : "loadNextPubInput(mutate payload)";
const finishGroth16Call = hasStruct ? "self.finishGroth16" : "finishGroth16";
const verifyPayloadCall = hasStruct ? "self.verifyPayload" : "groth16VerifyPayload";
const verifyProofCall = hasStruct
  ? `${verifierName}.create().verifyProof(msg)`
  : "verifyProof(msg)";

function multiexpName(k) {
  return hasStruct ? `${verifierName}.blsG1Multiexp${k}` : `blsG1Multiexp${k}`;
}

function directPoint(i) {
  return hasStruct ? `self.${icFieldName(i)}` : `IC${i}`;
}

function runtimePoint(expr) {
  return hasStruct ? `self.ic(${expr})` : `ic(${expr})`;
}

function renderMultiexpDecl(k) {
  const args = Array.from(
    { length: k },
    (_, i) => `  x${i + 1}: slice, y${i + 1}: int,`,
  ).join("\n");
  return [
    "/// # Safety",
    `/// Expects x1..x${k} to be canonical BLS12-381 G1 points and y1..y${k}`,
    '/// to be scalars encoded in the format expected by TVM `BLS_G1_MULTIEXP`.',
    "@pure",
    `fun ${multiexpName(k)}(`,
    args,
    "  n: int",
    '): slice asm "BLS_G1_MULTIEXP";',
  ].join("\n");
}

function renderPayloadScalarLoads(count, indent, declare) {
  return Array.from(
    { length: count },
    (_, i) => {
      const lhs = declare ? `val y${i + 1}: int` : `y${i + 1}`;
      return `${indent}${lhs} = ${loadNextPubInputCall};`;
    },
  ).join("\n");
}

function addExpr(base, offset) {
  return offset === 0 ? base : `${base} + ${offset}`;
}

function renderDirectPayloadBatchArgs(count, indent) {
  return Array.from(
    { length: count },
    (_, i) => `${indent}${directPoint(i + 1)}, y${i + 1}`,
  ).join(",\n");
}

function renderDirectArrayBatchArgs(count, indent) {
  return Array.from(
    { length: count },
    (_, i) => `${indent}${directPoint(i + 1)}, pubInputs.get(${i})`,
  ).join(",\n");
}

function renderRuntimePayloadBatchArgs(count, indent) {
  return Array.from(
    { length: count },
    (_, i) => `${indent}${runtimePoint(`done + ${i + 1}`)}, y${i + 1}`,
  ).join(",\n");
}

function renderRuntimeArrayBatchArgs(count, indent) {
  return Array.from(
    { length: count },
    (_, i) =>
      `${indent}${runtimePoint(`done + ${i + 1}`)}, pubInputs.get(${addExpr("done", i)})`,
  ).join(",\n");
}

function renderPayloadAccumulation() {
  if (nPublic === 0) {
    return "  // No public inputs, nothing to accumulate.";
  }

  if (nPublic <= maxBatch) {
    const lines = [];
    lines.push(renderPayloadScalarLoads(nPublic, "  ", true));
    lines.push(`  acc = ${multiexpName(nPublic)}(`);
    lines.push(renderDirectPayloadBatchArgs(nPublic, "    "));
    lines.push(`    , ${nPublic}`);
    lines.push("  );");
    lines.push("  haveAcc = true;");
    return lines.join("\n");
  }

  const lines = [
    "  // Multiple 7-sized batches plus an optional tail.",
    "  var done: int = 0;",
    `  val full: int = ${nPublicExpr} / 7;`,
    `  val rem:  int = ${nPublicExpr} % 7;`,
    "",
    "  while (done < full * 7) {",
    renderPayloadScalarLoads(7, "    ", true),
    `    val tmp: slice = ${multiexpName(7)}(`,
    renderRuntimePayloadBatchArgs(7, "      "),
    "      , 7",
    "    );",
    "",
    "    if (!haveAcc) {",
    "      acc = tmp;",
    "      haveAcc = true;",
    "    } else {",
    `      acc = ${addCall}(acc, tmp);`,
    "    }",
    "",
    "    done += 7;",
    "  }",
  ];

  const tailBranches = tailSizes
    .map((r, i) => {
      const cond = i === 0 ? "if" : "else if";
      return [
        `  ${cond} (rem == ${r}) {`,
        renderPayloadScalarLoads(r, "    ", true),
        `    val tail: slice = ${multiexpName(r)}(`,
        renderRuntimePayloadBatchArgs(r, "      "),
        `      , ${r}`,
        "    );",
        "",
        "    if (!haveAcc) {",
        "      acc = tail;",
        "      haveAcc = true;",
        "    } else {",
        `      acc = ${addCall}(acc, tail);`,
        "    }",
        "",
        `    done += ${r};`,
        "  }",
      ].join("\n");
    })
    .join("\n");

  if (tailBranches) {
    lines.push("");
    lines.push(tailBranches);
  }

  return lines.join("\n");
}

function renderArrayAccumulation() {
  if (nPublic === 0) {
    return "  // No public inputs, nothing to accumulate.";
  }

  if (nPublic <= maxBatch) {
    const lines = [];
    lines.push(`  acc = ${multiexpName(nPublic)}(`);
    lines.push(renderDirectArrayBatchArgs(nPublic, "    "));
    lines.push(`    , ${nPublic}`);
    lines.push("  );");
    lines.push("  haveAcc = true;");
    return lines.join("\n");
  }

  const lines = [
    "  // Multiple 7-sized batches plus an optional tail.",
    "  var done: int = 0;",
    `  val full: int = ${nPublicExpr} / 7;`,
    `  val rem:  int = ${nPublicExpr} % 7;`,
    "",
    "  while (done < full * 7) {",
    `    val tmp: slice = ${multiexpName(7)}(`,
    renderRuntimeArrayBatchArgs(7, "      "),
    "      , 7",
    "    );",
    "",
    "    if (!haveAcc) {",
    "      acc = tmp;",
    "      haveAcc = true;",
    "    } else {",
    `      acc = ${addCall}(acc, tmp);`,
    "    }",
    "",
    "    done += 7;",
    "  }",
  ];

  const tailBranches = tailSizes
    .map((r, i) => {
      const cond = i === 0 ? "if" : "else if";
      return [
        `  ${cond} (rem == ${r}) {`,
        `    val tail: slice = ${multiexpName(r)}(`,
        renderRuntimeArrayBatchArgs(r, "      "),
        `      , ${r}`,
        "    );",
        "",
        "    if (!haveAcc) {",
        "      acc = tail;",
        "      haveAcc = true;",
        "    } else {",
        `      acc = ${addCall}(acc, tail);`,
        "    }",
        "",
        `    done += ${r};`,
        "  }",
      ].join("\n");
    })
    .join("\n");

  if (tailBranches) {
    lines.push("");
    lines.push(tailBranches);
  }

  return lines.join("\n");
}

const multiexpDecls = uniqSizes.map((k) => renderMultiexpDecl(k)).join("\n\n");
const payloadAccumulation = renderPayloadAccumulation();
const arrayAccumulation = renderArrayAccumulation();
%>
contract <%= publicContractName %> {
  description: "Groth16 verifier generated by export-ton-verifier"
  storage: <%= storageName %>
  incomingMessages: <%= verifyMessageName %>
}

/// Empty persistent storage; verifier constants are embedded in code.
struct <%= storageName %> {}

<% if (hasStruct) { -%>
struct <%= verifierName %> {
<%- verifierFieldDecls %>
}
<% } else { -%>
// IC0 is the constant term
<%- icConstants %>

const VK_GAMMA_2: slice = "<%= vk_gamma_2 %>".hexToSlice()
const VK_DELTA_2: slice = "<%= vk_delta_2 %>".hexToSlice()
const VK_ALPHA_1: slice = "<%= vk_alpha_1 %>".hexToSlice()
const VK_BETA_2:  slice = "<%= vk_beta_2 %>".hexToSlice()

const N_PUBLIC: int = <%= nPublic %>
<% } -%>

enum <%= errorsName %> {
  InvalidInputs = 258,
<% if (nPublic > 7) { -%>
  IndexOutOfRange = 259,
<% } -%>
  WrongProof = 260,
}

<% if (hasStruct) { -%>
fun <%= verifierName %>.create(): <%= verifierName %> {
  return <%= verifierName %> {
<%- verifierFieldValues %>
  };
}
<% } -%>

/// # Safety
/// Expects both slices to contain canonically encoded BLS12-381 G1 points
/// accepted by the TVM `BLS_G1_ADD` opcode.
@pure fun <%= hasStruct ? `${verifierName}.blsG1Add` : "blsG1Add" %>(x: slice, y: slice): slice asm "BLS_G1_ADD";

/// # Safety
/// Expects the slice to contain a canonically encoded BLS12-381 G1 point
/// accepted by the TVM `BLS_G1_NEG` opcode.
@pure fun <%= hasStruct ? `${verifierName}.blsG1Neg` : "blsG1Neg" %>(x: slice): slice asm "BLS_G1_NEG";

/// # Safety
/// Expects the provided slices to contain canonically encoded BLS12-381 proof
/// and verification-key points in the order required by TVM `BLS_PAIRING`.
@pure fun <%= hasStruct ? `${verifierName}.blsPairing` : "blsPairing" %>(
  x1: slice, y1: slice,
  x2: slice, y2: slice,
  x3: slice, y3: slice,
  x4: slice, y4: slice,
  n: int
): int asm "BLS_PAIRING";

<% if (multiexpDecls) { -%>
<%- multiexpDecls %>
<% } -%>

<% if (nPublic > 7) { -%>
// IC selector for runtime batching. <% if (!hasStruct) { %>The points are inlined to avoid emitting IC1..ICN constants.<% } %>
fun <%= hasStruct ? `${verifierName}.ic(self, idx: int)` : "ic(idx: int)" %>: slice {
<%- icSelectorCases %>
  throw <%= errIndexOutOfRange %>;
}
<% } -%>

<% if (nPublic > 0) { -%>
// Internal messages carry public inputs as a custom payload:
// uint8 length, then int257 values chained through refs as needed.
<% } -%>
fun <%= hasStruct ? `${verifierName}.loadNextPubInput(mutate payload: slice)` : "loadNextPubInput(mutate payload: slice)" %>: int {
  if (payload.remainingBitsCount() < 257) {
    if (payload.remainingBitsCount() != 0 || payload.remainingRefsCount() == 0) {
      throw <%= errInvalidInputs %>;
    }
    payload = payload.loadRef().beginParse();
  }
  return payload.loadInt(257);
}

fun <%= hasStruct ? `${verifierName}.finishGroth16` : "finishGroth16" %>(
<% if (hasStruct) { -%>
  self,
<% } -%>
  piA: slice,
  piB: slice,
  piC: slice,
  acc: slice,
  haveAcc: bool
): bool {
  // Final cpub = IC0 + acc (IC0 is always added exactly once)
  var cpub: slice;
  if (!haveAcc) {
    cpub = <%= icZeroExpr %>;
  } else {
    cpub = <%= addCall %>(acc, <%= icZeroExpr %>);
  }

  // Pairing check: e(cpub, gamma) * e(-piA, piB) * e(piC, delta) * e(alpha, beta) == 1
  val piANeg: slice = <%= negCall %>(piA);
  val ok: int = <%= pairingCall %>(
    cpub,         <%= vkGammaExpr %>,
    piANeg,       piB,
    piC,          <%= vkDeltaExpr %>,
    <%= vkAlphaExpr %>, <%= vkBetaExpr %>,
    4
  );

  return ok != 0;
}

fun <%= hasStruct ? `${verifierName}.verifyPayload` : "groth16VerifyPayload" %>(
<% if (hasStruct) { -%>
  self,
<% } -%>
  piA: slice,
  piB: slice,
  piC: slice,
  mutate payload: slice
): bool {
  // Compute: cpub = IC0 + sum(pubInputs[i] * IC(i+1))
  var haveAcc: bool = false;
  var acc: slice = <%= icZeroExpr %>; // placeholder until haveAcc == true

<%- payloadAccumulation %>

  if (payload.remainingBitsCount() != 0 || payload.remainingRefsCount() != 0) {
    throw <%= errInvalidInputs %>;
  }

  return <%= finishGroth16Call %>(piA, piB, piC, acc, haveAcc);
}

fun <%- hasStruct ? `${verifierName}.verify(self, piA: slice, piB: slice, piC: slice, pubInputs: array<int>)` : "groth16VerifyArray(piA: slice, piB: slice, piC: slice, pubInputs: array<int>)" %>: bool {
  if (pubInputs.size() != <%= nPublicExpr %>) { throw <%= errInvalidInputs %>; }

  // Compute: cpub = IC0 + sum(pubInputs[i] * IC(i+1))
  var haveAcc: bool = false;
  var acc: slice = <%= icZeroExpr %>; // placeholder until haveAcc == true

<%- arrayAccumulation %>

  return <%= finishGroth16Call %>(piA, piB, piC, acc, haveAcc);
}

/// Internal message containing Groth16 proof points and serialized public inputs.
struct (0x3b3cca17) <%= verifyMessageName %> {
  /// G1 proof point piA.
  piA: cell
  /// G2 proof point piB.
  piB: cell
  /// G1 proof point piC.
  piC: cell
  /// uint8 length followed by int257 public inputs chained through refs.
  pubInputs: RemainingBitsAndRefs
}

fun <%= hasStruct ? `${verifierName}.verifyProof(self, msg: ${verifyMessageName})` : `verifyProof(msg: ${verifyMessageName})` %>: bool {
  val piA: slice = msg.piA.beginParse();
  val piB: slice = msg.piB.beginParse();
  val piC: slice = msg.piC.beginParse();
  var payload: slice = msg.pubInputs;

  if (payload.loadUint(8) != <%= nPublicExpr %>) { throw <%= errInvalidInputs %>; }

  return <%= verifyPayloadCall %>(piA, piB, piC, mutate payload);
}

<% if (hasStruct) { -%>
// Convenience standalone entrypoints. Remove or rename them when composing
// multiple verifier structs inside one contract.
<% } -%>
fun onInternalMessage(inMsg: InMessage) {
  val msg = lazy <%= verifyMessageName %>.fromSlice(inMsg.body);

  match (msg) {
    <%= verifyMessageName %> => {
      assert (<%= verifyProofCall %>) throw <%= errWrongProof %>;
    }
    else => {
      assert (inMsg.body.isEmpty()) throw <%= errInvalidInputs %>;
    }
  }
}

<% if (!hasStruct) { -%>
/// Verifies a Groth16 proof against public inputs.
get fun verify(piA: slice, piB: slice, piC: slice, pubInputs: array<int>): bool {
  return groth16VerifyArray(piA, piB, piC, pubInputs);
}
<% } -%>

<% if (hasStruct) { -%>
/// Verifies a Groth16 proof against public inputs.
get fun <%= verifyGetterName %>(piA: slice, piB: slice, piC: slice, pubInputs: array<int>): bool {
  return <%= verifierName %>.create().verify(piA, piB, piC, pubInputs);
}
<% } -%>
