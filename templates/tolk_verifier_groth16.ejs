<%
const maxBatch = 7;
let sizes = [];

if (nPublic > 0) {
  if (nPublic <= maxBatch) {
    sizes = [nPublic];
  } else {
    const fullBatches = Math.floor(nPublic / maxBatch);
    for (let i = 0; i < fullBatches; i++) sizes.push(maxBatch);
    const rem = nPublic % maxBatch;
    if (rem > 0) sizes.push(rem);
  }
}

const uniqSizes = [...new Set(sizes)];
const tailSizes = uniqSizes.filter((s) => s !== 7).sort((a, b) => a - b);
const pubInputNames = Array.from({ length: nPublic }, (_, i) => `pubInput${i}`);
const verifySignatureTail = pubInputNames.length
  ? `,\n${pubInputNames.map((name) => `  ${name}: int`).join(",\n")}`
  : "";
const verifyCallTail = pubInputNames.length
  ? `,\n${pubInputNames.map((name) => `    ${name}`).join(",\n")}`
  : "";
const getterCallTail = pubInputNames.length
  ? `,\n${pubInputNames.map((_, i) => `    pubInputs.get(${i})`).join(",\n")}`
  : "";
const icConstants = IC
  .map((point, i) => `const IC${i}: slice = "${point}".hexToSlice()`)
  .join("\n");
const icSelectorCases = IC
  .slice(1)
  .map((_, i) => `  if (idx == ${i + 1}) { return IC${i + 1}; }`)
  .join("\n");
const pubInputSelectorTail = pubInputNames.length
  ? `,\n${pubInputNames.map((name) => `  ${name}: int`).join(",\n")}`
  : "";
const pubInputSelectorCases = pubInputNames
  .map((name, i) => `  if (idx == ${i}) { return ${name}; }`)
  .join("\n");
const verifyProofLoads = pubInputNames
  .map((name) => `  var ${name}: int = loadNextPubInput(mutate payload);`)
  .join("\n");
const directBatchArgs = pubInputNames
  .map((name, i) => `    IC${i + 1}, ${name}`)
  .join(",\n");
const joinedPubInputNames = pubInputNames.join(", ");

function renderMultiexpDecl(k) {
  const args = Array.from(
    { length: k },
    (_, i) => `  x${i + 1}: slice, y${i + 1}: int,`,
  ).join("\n");
  return `@pure\nfun blsG1Multiexp_${k}(\n${args}\n  n: int\n): slice asm "BLS_G1_MULTIEXP";`;
}

function renderPubInputAtCall(idxExpr) {
  return `pubInputAt(${idxExpr}, ${joinedPubInputNames})`;
}

function renderRuntimeBatchArgs(count) {
  return Array.from({ length: count }, (_, i) => {
    const point = `ic(done + ${i + 1})`;
    const scalar = renderPubInputAtCall(`done + ${i}`);
    return `      ${point}, ${scalar}`;
  }).join(",\n");
}

const multiexpDecls = uniqSizes.map((k) => renderMultiexpDecl(k)).join("\n\n");
const tailBranches = tailSizes.map((r, i) => {
  const cond = i === 0 ? "if" : "else if";
  return `  ${cond} (rem == ${r}) {\n    var tail: slice = blsG1Multiexp_${r}(\n${renderRuntimeBatchArgs(r)}\n      , ${r}\n    );\n\n    if (!haveAcc) {\n      acc = tail;\n      haveAcc = true;\n    } else {\n      acc = blsG1Add(acc, tail);\n    }\n\n    done += ${r};\n  }`;
}).join("\n");
%>
// IC0 is the constant term
<%- icConstants %>

const VK_GAMMA_2: slice = "<%= vk_gamma_2 %>".hexToSlice()
const VK_DELTA_2: slice = "<%= vk_delta_2 %>".hexToSlice()
const VK_ALPHA_1: slice = "<%= vk_alpha_1 %>".hexToSlice()
const VK_BETA_2:  slice = "<%= vk_beta_2 %>".hexToSlice()

const N_PUBLIC: int = <%= nPublic %>

const ERR_INVALID_INPUTS: int = 258
<% if (nPublic > 7) { -%>
const ERR_INDEX_OUT_OF_RANGE: int = 259
<% } -%>
const ERR_WRONG_PROOF: int = 260

@pure fun blsG1Add(x: slice, y: slice): slice asm "BLS_G1_ADD";
@pure fun blsG1Neg(x: slice): slice       asm "BLS_G1_NEG";
@pure fun blsPairing(
  x1: slice, y1: slice,
  x2: slice, y2: slice,
  x3: slice, y3: slice,
  x4: slice, y4: slice,
  n: int
): int asm "BLS_PAIRING";

<% if (multiexpDecls) { -%>
<%- multiexpDecls %>
<% } -%>

<% if (nPublic > 7) { -%>
// IC selector for runtime index: 1 -> IC1, 2 -> IC2, ...
fun ic(idx: int): slice {
<%- icSelectorCases %>
  throw(ERR_INDEX_OUT_OF_RANGE);
}

// Public input selector for runtime-indexed batching.
fun pubInputAt(
  idx: int<%- pubInputSelectorTail %>
): int {
<%- pubInputSelectorCases %>
  throw(ERR_INDEX_OUT_OF_RANGE);
}
<% } -%>

<% if (nPublic > 0) { -%>
// Internal messages carry public inputs as a custom payload:
// uint8 length, then int257 values chained through refs as needed.
fun loadNextPubInput(mutate payload: slice): int {
  if (payload.remainingBitsCount() < 257) {
    if (payload.remainingBitsCount() != 0 || payload.remainingRefsCount() == 0) {
      throw(ERR_INVALID_INPUTS);
    }
    payload = payload.loadRef().beginParse();
  }
  return payload.loadInt(257);
}
<% } -%>

fun groth16Verify(
  piA: slice,
  piB: slice,
  piC: slice<%- verifySignatureTail %>
): bool {
  // Compute: cpub = IC0 + sum(pubInputs[i] * IC(i+1))
  var haveAcc: bool = false;
  var acc: slice = IC0; // placeholder until haveAcc == true

<% if (nPublic === 0) { -%>
  // No public inputs, nothing to accumulate.
<% } else if (nPublic <= 7) { -%>
  acc = blsG1Multiexp_<%= nPublic %>(
<%- directBatchArgs %>
    , <%= nPublic %>
  );
  haveAcc = true;
<% } else { -%>
  // Multiple 7-sized batches plus an optional tail.
  var done: int = 0;
  var full: int = N_PUBLIC / 7;
  var rem:  int = N_PUBLIC % 7;

  while (full > 0) {
    var tmp: slice = blsG1Multiexp_7(
<%- renderRuntimeBatchArgs(7) %>
      , 7
    );

    if (!haveAcc) {
      acc = tmp;
      haveAcc = true;
    } else {
      acc = blsG1Add(acc, tmp);
    }

    done += 7;
    full -= 1;
  }

<% if (tailBranches) { -%>
<%- tailBranches %>
<% } -%>
<% } -%>

  // Final cpub = IC0 + acc (IC0 is always added exactly once)
  var cpub: slice;
  if (!haveAcc) {
    cpub = IC0;
  } else {
    cpub = blsG1Add(acc, IC0);
  }

  // Pairing check: e(cpub, gamma) * e(-piA, piB) * e(piC, delta) * e(alpha, beta) == 1
  var piANeg: slice = blsG1Neg(piA);
  var ok: int = blsPairing(
    cpub,       VK_GAMMA_2,
    piANeg,     piB,
    piC,        VK_DELTA_2,
    VK_ALPHA_1, VK_BETA_2,
    4
  );

  return ok != 0;
}

struct (0x3b3cca17) Verify {
  piA: cell
  piB: cell
  piC: cell
  pubInputs: RemainingBitsAndRefs
}

fun verifyProof(msg: Verify): bool {
  var piA: slice = msg.piA.beginParse();
  var piB: slice = msg.piB.beginParse();
  var piC: slice = msg.piC.beginParse();
  var payload: slice = msg.pubInputs;

  if (payload.loadUint(8) != N_PUBLIC) { throw(ERR_INVALID_INPUTS); }
<% if (verifyProofLoads) { -%>
<%- verifyProofLoads %>
<% } -%>
  if (payload.remainingBitsCount() != 0 || payload.remainingRefsCount() != 0) {
    throw(ERR_INVALID_INPUTS);
  }

  return groth16Verify(
    piA,
    piB,
    piC<%- verifyCallTail %>
  );
}

fun onInternalMessage(inMsg: InMessage) {
  val msg = lazy Verify.fromSlice(inMsg.body);

  match (msg) {
    Verify => {
      assert(verifyProof(msg), ERR_WRONG_PROOF);
    }
    else => {}
  }
}

get fun verify(piA: slice, piB: slice, piC: slice, pubInputs: array<int>): bool {
  if (pubInputs.size() != N_PUBLIC) { throw(ERR_INVALID_INPUTS); }

  return groth16Verify(
    piA,
    piB,
    piC<%- getterCallTail %>
  );
}
