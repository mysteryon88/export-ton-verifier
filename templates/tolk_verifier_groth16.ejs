<%
const maxBatch = 7;
let sizes = [];

if (nPublic > 0) {
  if (nPublic <= maxBatch) {
    sizes = [nPublic];
  } else {
    const fullBatches = Math.floor(nPublic / maxBatch);
    for (let i = 0; i < fullBatches; i++) sizes.push(maxBatch);
    const rem = nPublic % maxBatch;
    if (rem > 0) sizes.push(rem);
  }
}

const uniqSizes = [...new Set(sizes)];
const tailSizes = uniqSizes.filter((s) => s !== 7).sort((a, b) => a - b);
const icConstants = IC
  .slice(0, nPublic > maxBatch ? 1 : undefined)
  .map((point, i) => `const IC${i}: slice = "${point}".hexToSlice()`)
  .join("\n");
const icSelectorCases = IC
  .slice(1)
  .map((point, i) => `  if (idx == ${i + 1}) { return "${point}".hexToSlice(); }`)
  .join("\n");

function renderMultiexpDecl(k) {
  const args = Array.from(
    { length: k },
    (_, i) => `  x${i + 1}: slice, y${i + 1}: int,`,
  ).join("\n");
  return `@pure\nfun blsG1Multiexp_${k}(\n${args}\n  n: int\n): slice asm "BLS_G1_MULTIEXP";`;
}

function renderPayloadScalarLoads(count, indent, declare) {
  return Array.from(
    { length: count },
    (_, i) => {
      const lhs = declare ? `var y${i + 1}: int` : `y${i + 1}`;
      return `${indent}${lhs} = loadNextPubInput(mutate payload);`;
    },
  ).join("\n");
}

function addExpr(base, offset) {
  return offset === 0 ? base : `${base} + ${offset}`;
}

function renderDirectPayloadBatchArgs(count, indent) {
  return Array.from(
    { length: count },
    (_, i) => `${indent}IC${i + 1}, y${i + 1}`,
  ).join(",\n");
}

function renderDirectArrayBatchArgs(count, indent) {
  return Array.from({ length: count }, (_, i) => {
    return `${indent}IC${i + 1}, pubInputs.get(${i})`;
  }).join(",\n");
}

function renderRuntimePayloadBatchArgs(count, indent) {
  return Array.from({ length: count }, (_, i) => {
    return `${indent}ic(done + ${i + 1}), y${i + 1}`;
  }).join(",\n");
}

function renderRuntimeArrayBatchArgs(count, indent) {
  return Array.from({ length: count }, (_, i) => {
    return `${indent}ic(done + ${i + 1}), pubInputs.get(${addExpr("done", i)})`;
  }).join(",\n");
}

function renderPayloadAccumulation() {
  if (nPublic === 0) {
    return "  // No public inputs, nothing to accumulate.";
  }

  if (nPublic <= maxBatch) {
    const lines = [];
    lines.push(renderPayloadScalarLoads(nPublic, "  ", true));
    lines.push(`  acc = blsG1Multiexp_${nPublic}(`);
    lines.push(renderDirectPayloadBatchArgs(nPublic, "    "));
    lines.push(`    , ${nPublic}`);
    lines.push("  );");
    lines.push("  haveAcc = true;");
    return lines.join("\n");
  }

  const lines = [
    "  // Multiple 7-sized batches plus an optional tail.",
    "  var done: int = 0;",
    "  var full: int = N_PUBLIC / 7;",
    "  var rem:  int = N_PUBLIC % 7;",
    "",
    "  while (full > 0) {",
    renderPayloadScalarLoads(7, "    ", true),
    "    var tmp: slice = blsG1Multiexp_7(",
    renderRuntimePayloadBatchArgs(7, "      "),
    "      , 7",
    "    );",
    "",
    "    if (!haveAcc) {",
    "      acc = tmp;",
    "      haveAcc = true;",
    "    } else {",
    "      acc = blsG1Add(acc, tmp);",
    "    }",
    "",
    "    done += 7;",
    "    full -= 1;",
    "  }",
  ];

  const tailBranches = tailSizes.map((r, i) => {
    const cond = i === 0 ? "if" : "else if";
    return [
      `  ${cond} (rem == ${r}) {`,
      renderPayloadScalarLoads(r, "    ", true),
      `    var tail: slice = blsG1Multiexp_${r}(`,
      renderRuntimePayloadBatchArgs(r, "      "),
      `      , ${r}`,
      "    );",
      "",
      "    if (!haveAcc) {",
      "      acc = tail;",
      "      haveAcc = true;",
      "    } else {",
      "      acc = blsG1Add(acc, tail);",
      "    }",
      "",
      `    done += ${r};`,
      "  }",
    ].join("\n");
  }).join("\n");

  if (tailBranches) {
    lines.push("");
    lines.push(tailBranches);
  }

  return lines.join("\n");
}

function renderArrayAccumulation() {
  if (nPublic === 0) {
    return "  // No public inputs, nothing to accumulate.";
  }

  if (nPublic <= maxBatch) {
    const lines = [];
    lines.push(`  acc = blsG1Multiexp_${nPublic}(`);
    lines.push(renderDirectArrayBatchArgs(nPublic, "    "));
    lines.push(`    , ${nPublic}`);
    lines.push("  );");
    lines.push("  haveAcc = true;");
    return lines.join("\n");
  }

  const lines = [
    "  // Multiple 7-sized batches plus an optional tail.",
    "  var done: int = 0;",
    "  var full: int = N_PUBLIC / 7;",
    "  var rem:  int = N_PUBLIC % 7;",
    "",
    "  while (full > 0) {",
    "    var tmp: slice = blsG1Multiexp_7(",
    renderRuntimeArrayBatchArgs(7, "      "),
    "      , 7",
    "    );",
    "",
    "    if (!haveAcc) {",
    "      acc = tmp;",
    "      haveAcc = true;",
    "    } else {",
    "      acc = blsG1Add(acc, tmp);",
    "    }",
    "",
    "    done += 7;",
    "    full -= 1;",
    "  }",
  ];

  const tailBranches = tailSizes.map((r, i) => {
    const cond = i === 0 ? "if" : "else if";
    return [
      `  ${cond} (rem == ${r}) {`,
      `    var tail: slice = blsG1Multiexp_${r}(`,
      renderRuntimeArrayBatchArgs(r, "      "),
      `      , ${r}`,
      "    );",
      "",
      "    if (!haveAcc) {",
      "      acc = tail;",
      "      haveAcc = true;",
      "    } else {",
      "      acc = blsG1Add(acc, tail);",
      "    }",
      "",
      `    done += ${r};`,
      "  }",
    ].join("\n");
  }).join("\n");

  if (tailBranches) {
    lines.push("");
    lines.push(tailBranches);
  }

  return lines.join("\n");
}

const multiexpDecls = uniqSizes.map((k) => renderMultiexpDecl(k)).join("\n\n");
const payloadAccumulation = renderPayloadAccumulation();
const arrayAccumulation = renderArrayAccumulation();
%>
// IC0 is the constant term
<%- icConstants %>

const VK_GAMMA_2: slice = "<%= vk_gamma_2 %>".hexToSlice()
const VK_DELTA_2: slice = "<%= vk_delta_2 %>".hexToSlice()
const VK_ALPHA_1: slice = "<%= vk_alpha_1 %>".hexToSlice()
const VK_BETA_2:  slice = "<%= vk_beta_2 %>".hexToSlice()

const N_PUBLIC: int = <%= nPublic %>

const ERR_INVALID_INPUTS: int = 258
<% if (nPublic > 7) { -%>
const ERR_INDEX_OUT_OF_RANGE: int = 259
<% } -%>
const ERR_WRONG_PROOF: int = 260

@pure fun blsG1Add(x: slice, y: slice): slice asm "BLS_G1_ADD";
@pure fun blsG1Neg(x: slice): slice       asm "BLS_G1_NEG";
@pure fun blsPairing(
  x1: slice, y1: slice,
  x2: slice, y2: slice,
  x3: slice, y3: slice,
  x4: slice, y4: slice,
  n: int
): int asm "BLS_PAIRING";

<% if (multiexpDecls) { -%>
<%- multiexpDecls %>
<% } -%>

<% if (nPublic > 7) { -%>
// IC selector for runtime batching. The points are inlined to avoid emitting IC1..ICN constants.
fun ic(idx: int): slice {
<%- icSelectorCases %>
  throw(ERR_INDEX_OUT_OF_RANGE);
}
<% } -%>

<% if (nPublic > 0) { -%>
// Internal messages carry public inputs as a custom payload:
// uint8 length, then int257 values chained through refs as needed.
fun loadNextPubInput(mutate payload: slice): int {
  if (payload.remainingBitsCount() < 257) {
    if (payload.remainingBitsCount() != 0 || payload.remainingRefsCount() == 0) {
      throw(ERR_INVALID_INPUTS);
    }
    payload = payload.loadRef().beginParse();
  }
  return payload.loadInt(257);
}
<% } -%>

fun finishGroth16(
  piA: slice,
  piB: slice,
  piC: slice,
  acc: slice,
  haveAcc: bool
): bool {
  // Final cpub = IC0 + acc (IC0 is always added exactly once)
  var cpub: slice;
  if (!haveAcc) {
    cpub = IC0;
  } else {
    cpub = blsG1Add(acc, IC0);
  }

  // Pairing check: e(cpub, gamma) * e(-piA, piB) * e(piC, delta) * e(alpha, beta) == 1
  var piANeg: slice = blsG1Neg(piA);
  var ok: int = blsPairing(
    cpub,       VK_GAMMA_2,
    piANeg,     piB,
    piC,        VK_DELTA_2,
    VK_ALPHA_1, VK_BETA_2,
    4
  );

  return ok != 0;
}

fun groth16VerifyPayload(
  piA: slice,
  piB: slice,
  piC: slice,
  mutate payload: slice
): bool {
  // Compute: cpub = IC0 + sum(pubInputs[i] * IC(i+1))
  var haveAcc: bool = false;
  var acc: slice = IC0; // placeholder until haveAcc == true

<%- payloadAccumulation %>

  if (payload.remainingBitsCount() != 0 || payload.remainingRefsCount() != 0) {
    throw(ERR_INVALID_INPUTS);
  }

  return finishGroth16(piA, piB, piC, acc, haveAcc);
}

fun groth16VerifyArray(
  piA: slice,
  piB: slice,
  piC: slice,
  pubInputs: array<int>
): bool {
  if (pubInputs.size() != N_PUBLIC) { throw(ERR_INVALID_INPUTS); }

  // Compute: cpub = IC0 + sum(pubInputs[i] * IC(i+1))
  var haveAcc: bool = false;
  var acc: slice = IC0; // placeholder until haveAcc == true

<%- arrayAccumulation %>

  return finishGroth16(piA, piB, piC, acc, haveAcc);
}

struct (0x3b3cca17) Verify {
  piA: cell
  piB: cell
  piC: cell
  pubInputs: RemainingBitsAndRefs
}

fun verifyProof(msg: Verify): bool {
  var piA: slice = msg.piA.beginParse();
  var piB: slice = msg.piB.beginParse();
  var piC: slice = msg.piC.beginParse();
  var payload: slice = msg.pubInputs;

  if (payload.loadUint(8) != N_PUBLIC) { throw(ERR_INVALID_INPUTS); }

  return groth16VerifyPayload(piA, piB, piC, mutate payload);
}

fun onInternalMessage(inMsg: InMessage) {
  val msg = lazy Verify.fromSlice(inMsg.body);

  match (msg) {
    Verify => {
      assert(verifyProof(msg), ERR_WRONG_PROOF);
    }
    else => {}
  }
}

get fun verify(piA: slice, piB: slice, piC: slice, pubInputs: array<int>): bool {
  return groth16VerifyArray(piA, piB, piC, pubInputs);
}
