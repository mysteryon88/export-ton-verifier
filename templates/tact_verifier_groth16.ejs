<%
const maxBatch = 7;
let sizes = [];

if (nPublic <= 0) {
  sizes = [];
} else if (nPublic <= maxBatch) {
  sizes = [nPublic];
} else {
  const fullBatches = Math.floor(nPublic / maxBatch);
  for (let i = 0; i < fullBatches; i++) sizes.push(maxBatch);
  const rem = nPublic % maxBatch;
  if (rem > 0) sizes.push(rem);
}

const uniqSizes = [...new Set(sizes)];
const fullBatches = Math.floor(nPublic / 7);
const tailSize = nPublic % 7;
const emittedIC = nPublic > maxBatch ? IC.slice(0, 1) : IC;
const icConstants = emittedIC
  .map((point, i) => `const IC${i}: Slice = rawSlice("${point}");`)
  .join("\n");
const icSelectorCases = IC
  .slice(1)
  .map((point, i) => `  if (idx == ${i + 1}) { return rawSlice("${point}"); }`)
  .join("\n");
const singleBatchArgs = Array.from({ length: nPublic }, (_, i) => {
  return `      IC${i + 1}, getPub(pubInputs, ${i})`;
}).join(",\n");
const fullBatchArgs = Array.from({ length: 7 }, (_, i) => {
  return `        ic(done + ${i + 1}), getPub(pubInputs, done + ${i})`;
}).join(",\n");
const tailBatchArgs = Array.from({ length: tailSize }, (_, i) => {
  return `      ic(done + ${i + 1}), getPub(pubInputs, done + ${i})`;
}).join(",\n");

function renderMultiexpDecl(k) {
  const args = Array.from(
    { length: k },
    (_, i) => `  x${i + 1}: Slice, y${i + 1}: Int${i < k - 1 ? "," : ""}`,
  ).join("\n");
  return `asm fun blsG1Multiexp_${k}(\n${args}\n  , n: Int\n): Slice { BLS_G1_MULTIEXP }`;
}

const multiexpDecls = uniqSizes.map((k) => renderMultiexpDecl(k)).join("\n\n");
%>
// ASM intrinsics
asm fun blsG1Add(x: Slice, y: Slice): Slice { BLS_G1_ADD }
asm fun blsG1Neg(x: Slice): Slice { BLS_G1_NEG }
asm fun blsPairing(
  x1: Slice, y1: Slice,
  x2: Slice, y2: Slice,
  x3: Slice, y3: Slice,
  x4: Slice, y4: Slice,
  n: Int
): Int { BLS_PAIRING }

<% if (multiexpDecls) { -%>
<%- multiexpDecls %>
<% } -%>

// Verification key constants
const vk_gamma_2: Slice = rawSlice("<%= vk_gamma_2 %>");
const vk_delta_2: Slice = rawSlice("<%= vk_delta_2 %>");
const vk_alpha_1: Slice = rawSlice("<%= vk_alpha_1 %>");
const vk_beta_2 : Slice = rawSlice("<%= vk_beta_2 %>");

// IC constants (IC0 is the constant term)
<%- icConstants %>

// Error codes
<% if (nPublic > 0) { -%>
const ERR_PUBLIC_NOT_PRESENT: Int = 257;
<% } -%>
const ERR_TOO_MANY_PUBLICS: Int = 258;
const ERR_WRONG_PROOF: Int = 260;

<% if (nPublic > 7) { -%>
// IC selection helper by index: 1 -> IC1, 2 -> IC2, ...
fun ic(idx: Int): Slice {
<%- icSelectorCases %>
  return IC0; // Unreachable for generated batches
}
<% } -%>

<% if (nPublic > 0) { -%>
fun assertNoExtraPubInputs(pubInputs: map<Int as uint32, Int>) {
  foreach (key, _ in pubInputs) {
    nativeThrowUnless(ERR_TOO_MANY_PUBLICS, key < <%= nPublic %>);
  }
}

// Safe getter for public inputs: throws ERR_PUBLIC_NOT_PRESENT
fun getPub(pubInputs: map<Int as uint32, Int>, k: Int): Int {
  let v = pubInputs.get(k);
  if (v == null) {
    nativeThrow(ERR_PUBLIC_NOT_PRESENT);
  }
  return v!!;
}
<% } -%>

// Message definition
message (0x3b3cca17) Verify {
  piA: Slice;
  piB: Slice;
  piC: Slice;
  pubInputs: map<Int as uint32, Int>;
}

contract Verifier {

  receive(msg: Verify) {
    let res = self.groth16Verify(msg.piA, msg.piB, msg.piC, msg.pubInputs);
    nativeThrowUnless(ERR_WRONG_PROOF, res);
  }

  receive() {}

  fun groth16Verify(
    piA: Slice,
    piB: Slice,
    piC: Slice,
    pubInputs: map<Int as uint32, Int>
  ): Bool {

<% if (nPublic === 0) { -%>
    // No public inputs allowed
    nativeThrowUnless(ERR_TOO_MANY_PUBLICS, pubInputs.isEmpty());
    let cpub: Slice = IC0;
<% } else if (nPublic <= 7) { -%>
    assertNoExtraPubInputs(pubInputs);

    // Single batch (no loop and no ic())
    let acc: Slice = blsG1Multiexp_<%= nPublic %>(
<%- singleBatchArgs %>
      , <%= nPublic %>
    );

    let cpub: Slice = blsG1Add(acc, IC0);

<% } else { -%>
    assertNoExtraPubInputs(pubInputs);

    // First full batch of 7
    let done: Int = 0;
    let batchesLeft: Int = <%= fullBatches %>;
    let acc: Slice = blsG1Multiexp_7(
<%- fullBatchArgs %>
        , 7
    );

    done += 7;
    batchesLeft -= 1;

    // Remaining full batches of 7
    while (batchesLeft > 0) {
      let tmp: Slice = blsG1Multiexp_7(
<%- fullBatchArgs %>
        , 7
      );

      acc = blsG1Add(acc, tmp);

      done += 7;
      batchesLeft -= 1;
    }

<% if (tailSize > 0) { -%>
    // Tail batch for remaining <%= tailSize %>
    let tail: Slice = blsG1Multiexp_<%= tailSize %>(
<%- tailBatchArgs %>
      , <%= tailSize %>
    );

    acc = blsG1Add(acc, tail);

    done += <%= tailSize %>;
<% } -%>

    let cpub: Slice = blsG1Add(acc, IC0);
<% } -%>

    // Pairing check
    let piANeg: Slice = blsG1Neg(piA);
    let ok: Int = blsPairing(
      cpub,       vk_gamma_2,
      piANeg,     piB,
      piC,        vk_delta_2,
      vk_alpha_1, vk_beta_2,
      4
    );

    return ok != 0;
  }

  get fun verify(
    piA: Slice,
    piB: Slice,
    piC: Slice,
    pubInputs: map<Int as uint32, Int>
  ): Bool {
    return self.groth16Verify(piA, piB, piC, pubInputs);
  }
}
