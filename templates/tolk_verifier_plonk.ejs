<%
const publicCount = Number(nPublic);
const powerValue = Number(power);
const domainSize = 2 ** powerValue;
const nLagrange = Math.max(publicCount, 1);
const publicContractName =
  typeof contractName === "string" && contractName.trim() !== ""
    ? contractName.trim()
    : "Verifier";
const storageName = `${publicContractName}Storage`;
const errorsName = `${publicContractName}Errors`;
const errPublicNotPresent = `${errorsName}.PublicNotPresent`;
const errFailedInverse = `${errorsName}.FailedInverse`;
const errScalarNotInField = `${errorsName}.ScalarNotInField`;
const errTooManyPublics = `${errorsName}.TooManyPublics`;
const errInvalidMessage = `${errorsName}.InvalidMessage`;

const xinSquares = Array.from(
  { length: powerValue },
  () => "  xin = mulmod(xin, xin, blsR());",
).join("\n");
const inverseSeedLines = Array.from({ length: nLagrange }, (_, index) => {
  const i = index + 1;
  const lines = [
    `  invs.setAt(${i}, mulmod(DOMAIN_SIZE, normalizeMod(xi - w, blsR()), blsR()));`,
  ];
  if (i < nLagrange) {
    lines.push("  w = mulmod(w, W1, blsR());");
  }
  return lines.join("\n");
}).join("\n");
const lagrangeEvalLines = Array.from({ length: nLagrange }, (_, index) => {
  const i = index + 1;
  const lines = [
    i === 1
      ? "  var evalL1: int = mulmod(invd.read(1), zh, blsR());"
      : `  restEvals.setAt(${i}, mulmod(w, mulmod(invd.read(${i}), zh, blsR()), blsR()));`,
  ];
  if (i < nLagrange) {
    lines.push("  w = mulmod(w, W1, blsR());");
  }
  return lines.join("\n");
}).join("\n");
const publicInputEvalLines = Array.from({ length: publicCount }, (_, i) => {
  if (i === 0) {
    return "  pl = normalizeMod(pl - mulmod(evalL1, publicInputs.read(0), blsR()), blsR());";
  }
  return `  pl = normalizeMod(pl - mulmod(restEvals.read(${i + 1}), publicInputs.read(${i}), blsR()), blsR());`;
}).join("\n");
%>
contract <%= publicContractName %> {
  description: "PLONK verifier generated by export-ton-verifier"
  storage: <%= storageName %>
}

/// Empty persistent storage; verifier constants are embedded in code.
struct <%= storageName %> {}

type ScalarMap = map<uint32, uint256>

// Compressed G1 points for BLS operations (48 bytes each).
const QM: slice = "<%= Qm %>".hexToSlice()
const QL: slice = "<%= Ql %>".hexToSlice()
const QR: slice = "<%= Qr %>".hexToSlice()
const QO: slice = "<%= Qo %>".hexToSlice()
const QC: slice = "<%= Qc %>".hexToSlice()
const S1: slice = "<%= S1 %>".hexToSlice()
const S2: slice = "<%= S2 %>".hexToSlice()
const S3: slice = "<%= S3 %>".hexToSlice()
const X_2: slice = "<%= X_2 %>".hexToSlice()

// Uncompressed G1 points for the snarkjs-compatible Keccak256 transcript.
const QM_UC: slice = "<%= Qm_uc %>".hexToSlice()
const QL_UC: slice = "<%= Ql_uc %>".hexToSlice()
const QR_UC: slice = "<%= Qr_uc %>".hexToSlice()
const QO_UC: slice = "<%= Qo_uc %>".hexToSlice()
const QC_UC: slice = "<%= Qc_uc %>".hexToSlice()
const S1_UC: slice = "<%= S1_uc %>".hexToSlice()
const S2_UC: slice = "<%= S2_uc %>".hexToSlice()
const S3_UC: slice = "<%= S3_uc %>".hexToSlice()

const K1: int = <%= k1 %>
const K2: int = <%= k2 %>
const W1: int = <%= w %>

const N_PUBLIC: int = <%= publicCount %>
const DOMAIN_SIZE: int = <%= domainSize %>
const N_LAGRANGE: int = <%= nLagrange %>

const BLS_G1: slice = "97f1d3a73197d7942695638c4fa9ac0fc3688c4f9774b905a14e3a3f171bac586c55e83ff97a1aeffb3af00adb22c6bb".hexToSlice()
const BLS_G2: slice = "93e02b6052719f607dacd3a088274f65596bd0d09920b61ab5da61bbdc7f5049334cf11213945d57e5ac7d055d042b7e024aa2b2f08f0a91260805272dc51051c6e47ad4fa403b02b4510b647ae3d1770bac0326a805bbefd48056c8c121bdb8".hexToSlice()

enum <%= errorsName %> {
  PublicNotPresent = 101,
  FailedInverse = 102,
  ScalarNotInField = 103,
  TooManyPublics = 104,
  InvalidMessage = 105,
}

/// # Safety
/// Expects two BLS12-381 G1/G2 pairs in the order required by TVM `BLS_PAIRING`.
@pure
fun blsPairing(ag1: slice, ag2: slice, bg1: slice, bg2: slice): int asm "2 PUSHINT BLS_PAIRING";

/// Keccak256 transcript hash compatible with snarkjs PLONK.
@pure
fun keccak256Tuple(p: tuple): int asm "255 PUSHINT EXPLODEVAR HASHEXT_KECCAK256";

@pure
fun blsR(): int asm "BLS_PUSHR";

@pure
fun mulmod(x: int, y: int, z: int): int asm "MULMOD";

/// # Safety
/// Expects both slices to contain canonically encoded BLS12-381 G1 points.
@pure
fun blsG1Add(a: slice, b: slice): slice asm "BLS_G1_ADD";

/// # Safety
/// Expects the slice to contain a canonically encoded BLS12-381 G1 point.
@pure
fun blsG1Mul(x: slice, s: int): slice asm "BLS_G1_MUL";

/// # Safety
/// Expects both slices to contain canonically encoded BLS12-381 G1 points.
@pure
fun blsG1Sub(a: slice, b: slice): slice asm "BLS_G1_SUB";

/// # Safety
/// Expects the slice to contain a canonically encoded BLS12-381 G1 point.
@pure
fun blsG1Neg(a: slice): slice asm "BLS_G1_NEG";

fun normalizeMod(x: int, z: int): int {
  var res: int = x % z;
  if (res < 0) {
    res += z;
  }
  return res;
}

fun addmod(x: int, y: int, z: int): int {
  return normalizeMod(x + y, z);
}

/// Convert a scalar to the 32-byte big-endian slice used by the transcript.
fun int.scalarToSlice(self): slice {
  return beginCell().storeUint(self, 256).endCell().beginParse();
}

fun ffInverse(a: int, q: int): int {
  var t: int = 0;
  var newt: int = 1;
  var r: int = q;
  var newr: int = normalizeMod(a, q);
  var quotient: int = 0;
  var aux: int = 0;

  while (newr != 0) {
    quotient = r / newr;
    aux = t - quotient * newt;
    t = newt;
    newt = aux;

    aux = r - quotient * newr;
    r = newr;
    newr = aux;
  }

  if (r > 1) {
    throw <%= errFailedInverse %>;
  }

  if (t < 0) {
    t += q;
  }

  return t;
}

fun ScalarMap.read(self, i: int): int {
  val found = self.get(i as uint32);
  if (!found.isFound) {
    throw <%= errPublicNotPresent %>;
  }
  return found.loadValue() as int;
}

fun ScalarMap.setAt(mutate self, i: int, v: int): void {
  self.set(i as uint32, normalizeMod(v, blsR()) as uint256);
}

fun inverseArray(vals: ScalarMap, n: int): ScalarMap {
  var aux: ScalarMap = [];
  var acc: int = vals.read(0);
  var i: int = 1;

  while (i < n) {
    aux.setAt(i, acc);
    acc = mulmod(acc, vals.read(i), blsR());
    i += 1;
  }

  acc = ffInverse(acc, blsR());
  i -= 1;

  while (i > 0) {
    val inv = mulmod(acc, aux.read(i), blsR());
    acc = mulmod(acc, vals.read(i), blsR());
    vals.setAt(i, inv);
    i -= 1;
  }

  vals.setAt(0, acc);
  return vals;
}

fun checkField(x: int): void {
  if (x < 0 || x >= blsR()) {
    throw <%= errScalarNotInField %>;
  }
}

fun checkPublicInputCount(publicInputs: ScalarMap, nExpected: int): void {
  var count: int = 0;
  var cursor = publicInputs.findFirst();

  while (cursor.isFound) {
    val key = cursor.getKey() as int;
    if (key >= nExpected) {
      throw <%= errTooManyPublics %>;
    }
    count += 1;
    cursor = publicInputs.iterateNext(cursor);
  }

  if (count != nExpected) {
    throw <%= errPublicNotPresent %>;
  }
}

fun onInternalMessage(inMsg: InMessage) {
  // This verifier is getter-only; empty internal messages are allowed as top-ups.
  assert (inMsg.body.isEmpty()) throw <%= errInvalidMessage %>;
}

/// Verifies a snarkjs-compatible PLONK proof.
get fun verify(
  a: slice, b: slice, c: slice, z: slice, t1: slice, t2: slice, t3: slice,
  evalA: int, evalB: int, evalC: int, evalS1: int, evalS2: int, evalZw: int,
  wxi: slice, wxiw: slice,
  publicInputs: ScalarMap,
  aUc: slice, bUc: slice, cUc: slice, zUc: slice,
  t1Uc: slice, t2Uc: slice, t3Uc: slice,
  wxiUc: slice, wxiwUc: slice
): bool {
  checkField(evalA);
  checkField(evalB);
  checkField(evalC);
  checkField(evalS1);
  checkField(evalS2);
  checkField(evalZw);

  // Challenge round 2: beta.
  var betaHash: tuple = [];
  betaHash.push(QM_UC);
  betaHash.push(QL_UC);
  betaHash.push(QR_UC);
  betaHash.push(QO_UC);
  betaHash.push(QC_UC);
  betaHash.push(S1_UC);
  betaHash.push(S2_UC);
  betaHash.push(S3_UC);

  var pi: int = 0;
  while (pi < N_PUBLIC) {
    betaHash.push(publicInputs.read(pi).scalarToSlice());
    pi += 1;
  }
  checkPublicInputCount(publicInputs, N_PUBLIC);

  betaHash.push(aUc);
  betaHash.push(bUc);
  betaHash.push(cUc);

  val beta = keccak256Tuple(betaHash) % blsR();

  // Challenge: gamma.
  var gammaHash: tuple = [];
  gammaHash.push(beta.scalarToSlice());
  val gamma = keccak256Tuple(gammaHash) % blsR();

  // Challenge round 3: alpha.
  var alphaHash: tuple = [];
  alphaHash.push(beta.scalarToSlice());
  alphaHash.push(gamma.scalarToSlice());
  alphaHash.push(zUc);
  val alpha = keccak256Tuple(alphaHash) % blsR();

  val alpha2 = mulmod(alpha, alpha, blsR());

  // Challenge round 4: xi.
  var xiHash: tuple = [];
  xiHash.push(alpha.scalarToSlice());
  xiHash.push(t1Uc);
  xiHash.push(t2Uc);
  xiHash.push(t3Uc);
  val xi = keccak256Tuple(xiHash) % blsR();

  val betaXi = mulmod(beta, xi, blsR());
  var xin: int = xi;

<% if (xinSquares) { -%>
<%- xinSquares %>
<% } -%>

  val zh = normalizeMod(xin - 1, blsR());
  var invs: ScalarMap = [];
  invs.setAt(0, zh);

  // Challenge round 5: v.
  var vHash: tuple = [];
  vHash.push(xi.scalarToSlice());
  vHash.push(evalA.scalarToSlice());
  vHash.push(evalB.scalarToSlice());
  vHash.push(evalC.scalarToSlice());
  vHash.push(evalS1.scalarToSlice());
  vHash.push(evalS2.scalarToSlice());
  vHash.push(evalZw.scalarToSlice());

  val v1 = keccak256Tuple(vHash) % blsR();
  val v2 = mulmod(v1, v1, blsR());
  val v3 = mulmod(v2, v1, blsR());
  val v4 = mulmod(v3, v1, blsR());
  val v5 = mulmod(v4, v1, blsR());

  // Challenge: u.
  var uHash: tuple = [];
  uHash.push(wxiUc);
  uHash.push(wxiwUc);
  val u = keccak256Tuple(uHash) % blsR();

  // Lagrange evaluations.
  var w: int = 1;

<%- inverseSeedLines %>

  val invd = inverseArray(invs, N_LAGRANGE + 1);
  var restEvals: ScalarMap = [];

  w = 1;

<%- lagrangeEvalLines %>

  // PI (public input polynomial evaluation).
  var pl: int = 0;

<% if (publicInputEvalLines) { -%>
<%- publicInputEvalLines %>
<% } -%>

  // Compute linearization polynomial commitment.
  val e1 = pl;
  val e2 = mulmod(evalL1, alpha2, blsR());

  var e3a = addmod(evalA, mulmod(beta, evalS1, blsR()), blsR());
  e3a = addmod(e3a, gamma, blsR());

  var e3b = addmod(evalB, mulmod(beta, evalS2, blsR()), blsR());
  e3b = addmod(e3b, gamma, blsR());

  val e3c = addmod(evalC, gamma, blsR());

  var e3 = mulmod(mulmod(e3a, e3b, blsR()), e3c, blsR());
  e3 = mulmod(e3, evalZw, blsR());
  e3 = mulmod(e3, alpha, blsR());

  var r0 = addmod(e1, (-e2) % blsR(), blsR());
  r0 = addmod(r0, (-e3) % blsR(), blsR());

  // D polynomial commitment.
  var d1 = blsG1Mul(QM, mulmod(evalA, evalB, blsR()));
  d1 = blsG1Add(d1, blsG1Mul(QL, evalA));
  d1 = blsG1Add(d1, blsG1Mul(QR, evalB));
  d1 = blsG1Add(d1, blsG1Mul(QO, evalC));
  d1 = blsG1Add(d1, QC);

  val d2a1 = addmod(addmod(evalA, betaXi, blsR()), gamma, blsR());
  val d2a2 = addmod(addmod(evalB, mulmod(betaXi, K1, blsR()), blsR()), gamma, blsR());
  val d2a3 = addmod(addmod(evalC, mulmod(betaXi, K2, blsR()), blsR()), gamma, blsR());

  var d2a = mulmod(d2a1, d2a2, blsR());
  d2a = mulmod(d2a, d2a3, blsR());
  d2a = mulmod(d2a, alpha, blsR());

  val d2b = mulmod(evalL1, alpha2, blsR());
  val d2 = blsG1Mul(z, addmod(addmod(d2a, d2b, blsR()), u, blsR()));

  val d3a = addmod(addmod(evalA, mulmod(beta, evalS1, blsR()), blsR()), gamma, blsR());
  val d3b = addmod(addmod(evalB, mulmod(beta, evalS2, blsR()), blsR()), gamma, blsR());
  val d3c = mulmod(mulmod(alpha, beta, blsR()), evalZw, blsR());

  val d3 = blsG1Mul(S3, mulmod(mulmod(d3a, d3b, blsR()), d3c, blsR()));

  val d4low = t1;
  val d4mid = blsG1Mul(t2, xin);
  val d4high = blsG1Mul(t3, mulmod(xin, xin, blsR()));
  var d4 = blsG1Add(d4low, blsG1Add(d4mid, d4high));
  d4 = blsG1Mul(d4, zh);

  val d = blsG1Sub(blsG1Sub(blsG1Add(d1, d2), d3), d4);

  // F polynomial commitment.
  var f = blsG1Add(d, blsG1Mul(a, v1));
  f = blsG1Add(f, blsG1Mul(b, v2));
  f = blsG1Add(f, blsG1Mul(c, v3));
  f = blsG1Add(f, blsG1Mul(S1, v4));
  f = blsG1Add(f, blsG1Mul(S2, v5));

  // E polynomial commitment.
  var e = addmod((-r0) % blsR(), mulmod(v1, evalA, blsR()), blsR());
  e = addmod(e, mulmod(v2, evalB, blsR()), blsR());
  e = addmod(e, mulmod(v3, evalC, blsR()), blsR());
  e = addmod(e, mulmod(v4, evalS1, blsR()), blsR());
  e = addmod(e, mulmod(v5, evalS2, blsR()), blsR());
  e = addmod(e, mulmod(u, evalZw, blsR()), blsR());

  val eCommitment = blsG1Mul(BLS_G1, e);

  // Final pairing check.
  var a1 = wxi;
  a1 = blsG1Add(a1, blsG1Mul(wxiw, u));

  var b1 = blsG1Mul(wxi, xi);
  val s = mulmod(mulmod(u, xi, blsR()), W1, blsR());
  b1 = blsG1Add(b1, blsG1Mul(wxiw, s));
  b1 = blsG1Add(b1, f);
  b1 = blsG1Sub(b1, eCommitment);

  return blsPairing(blsG1Neg(a1), X_2, b1, BLS_G2) != 0;
}
